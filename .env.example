# ============================================================
# GOLM Lead-Gen Funnel — Environment Variables
# ============================================================
# Copy this file to .env.local and fill in real values.
# NEVER commit .env.local or any file containing real secrets.
#
# Scoping rules:
#   NEXT_PUBLIC_* vars are bundled into the client — safe for
#   public keys only, visible to anyone with the page source.
#   Variables WITHOUT NEXT_PUBLIC_ are server-only — they are
#   only available in Server Actions and route handlers and
#   never reach the browser bundle.
# ============================================================

# ------------------------------------------------------------
# Supabase — public (client init)
# ------------------------------------------------------------

# Supabase project URL. Safe to expose; needed by the browser
# client if used, and by the server client. Found in Supabase
# dashboard > Project Settings > API > Project URL.
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co

# Supabase anonymous (public) key. Safe to expose. However,
# RLS is enabled with no anon table policies, so this key has
# no read or write access to any table even if leaked.
# Found in Supabase dashboard > Project Settings > API > anon key.
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-supabase-anon-key

# ------------------------------------------------------------
# Supabase — server only (never expose to client)
# ------------------------------------------------------------

# Supabase service role key. Bypasses RLS — grants full read
# and write access to all tables. Used ONLY in Server Actions
# (lib/supabase-server.ts). Never prefix with NEXT_PUBLIC_.
# Found in Supabase dashboard > Project Settings > API > service_role key.
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ------------------------------------------------------------
# Resend — server only (never expose to client)
# ------------------------------------------------------------

# Resend transactional email API key. Used ONLY on the server
# to send result emails and Hot-lead internal alerts.
# Found in Resend dashboard > API Keys.
# Domain must be verified in Resend before live sending.
RESEND_API_KEY=re_your_resend_api_key

# ------------------------------------------------------------
# Cloudflare Turnstile — public site key (widget)
# ------------------------------------------------------------

# Turnstile site key embedded in the quiz form widget. Safe to
# expose — it identifies your widget but provides no server
# privileges. Found in Cloudflare dashboard > Turnstile > your widget.
NEXT_PUBLIC_TURNSTILE_SITE_KEY=your-turnstile-site-key

# ------------------------------------------------------------
# Cloudflare Turnstile — server only (verification secret)
# ------------------------------------------------------------

# Turnstile secret key used server-side to verify challenge
# tokens submitted with the quiz form. Never expose to client.
# Found in Cloudflare dashboard > Turnstile > your widget > Secret key.
TURNSTILE_SECRET_KEY=your-turnstile-secret-key

# ------------------------------------------------------------
# Booking — public CTA URL
# ------------------------------------------------------------

# Full URL of the call-booking page shown to Hot leads on the
# result page. Set to your Cal.com / Calendly / custom link
# before launch. Safe to expose — it is a public CTA link.
BOOKING_URL=https://your-booking-link.example.com

# ------------------------------------------------------------
# Site URL — public (used in server-side email links)
# ------------------------------------------------------------

# Full public URL of the deployed site. Used to construct result
# page links in emails (e.g. https://your-site.vercel.app/results/[token]).
# Must NOT have a trailing slash. Safe to expose.
NEXT_PUBLIC_SITE_URL=https://your-site.vercel.app

# ------------------------------------------------------------
# Analytics — public measurement IDs (NEXT_PUBLIC_ = safe to expose)
# ------------------------------------------------------------

# Google Analytics 4 measurement ID (format: G-XXXXXXXXXX).
# Found in GA4 dashboard > Admin > Data Streams > Web stream details.
# Scripts are not injected until this is set (no empty script tags in prod).
NEXT_PUBLIC_GA4_MEASUREMENT_ID=G-XXXXXXXXXX

# Microsoft Clarity project ID.
# Found in Clarity dashboard > Settings > Overview > Project ID.
# Scripts are not injected until this is set.
NEXT_PUBLIC_CLARITY_PROJECT_ID=your-clarity-project-id

# ------------------------------------------------------------
# Sentry — server only (never expose to client)
# ------------------------------------------------------------

# Sentry DSN for server-side error reporting on the submit path.
# Found in Sentry dashboard > Settings > Projects > <project> > Client Keys (DSN).
# Leave blank to run in dry-run mode (errors logged to console only).
SENTRY_DSN=https://your-key@your-org.ingest.sentry.io/your-project-id
